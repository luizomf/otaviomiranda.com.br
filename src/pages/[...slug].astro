---
/**
 * ARQUIVO: [...slug].astro
 *
 * O QUE FAZ:
 *   Pagina dinamica que renderiza cada post individual do blog. Busca todos os
 *   posts da content collection "posts", gera um caminho (slug) para cada um
 *   via getEntrySlugPath, e renderiza o conteudo Markdown como HTML. Exibe
 *   titulo, autor, data de publicacao e o corpo do artigo.
 *
 * USADO EM:
 *   - Qualquer URL de post, por exemplo:
 *     https://otaviomiranda.com.br/2024/meu-post-exemplo/
 *     O slug pode conter barras (ex: "2024/titulo-do-post"), por isso usa
 *     o rest parameter [...slug] em vez de [slug].
 *
 * CONCEITO ASTRO:
 *   Rest parameters em rotas dinamicas — o [...slug] (com "...") captura
 *   multiplos segmentos de URL (ex: /2024/titulo vira slug = "2024/titulo").
 *   Diferente de [slug], que captura apenas UM segmento.
 *
 *   getStaticPaths() — funcao OBRIGATORIA em rotas dinamicas no modo SSG
 *   (Static Site Generation). Ela roda no build e retorna um array de objetos
 *   { params, props } que dizem ao Astro QUAIS paginas gerar. Cada objeto
 *   gera uma pagina HTML estatica.
 *
 *   Content Collections — os posts ficam em src/content/posts/ e sao
 *   acessados via getCollection('posts'). A funcao render(entry) converte
 *   o Markdown/MDX em um componente <Content /> que pode ser usado no template.
 *
 *   Astro.props — recebe os dados passados pelo objeto "props" retornado
 *   em getStaticPaths(). Aqui, recebe a entry completa do post.
 */
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Newsletter from '../components/Newsletter.astro';
import { getEntrySlugPath } from '../utils/post-path';
import Section from '../components/Section.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('posts');
  return blogEntries.map((entry: CollectionEntry<'posts'>) => {
    const slugPath = getEntrySlugPath(entry);

    return {
      params: { slug: slugPath },
      props: { entry },
    };
  });
}

interface Props {
  entry: CollectionEntry<'posts'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const postImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/posts/**/images/*.{png,jpg,jpeg,gif,webp,avif}',
  { eager: true },
);

const site = Astro.site ?? new URL('https://otaviomiranda.com.br');

function getEntryDir(entryId: string): string {
  return entryId.replace(/\/[^/]+$/, '');
}

function getPostImageKey(
  imageReference: string,
  entryId: string,
): string | undefined {
  const image = imageReference.trim();
  if (!image) return undefined;

  const entryDir = getEntryDir(entryId);
  let pathname: string;

  if (image.startsWith('http://') || image.startsWith('https://')) {
    const imageUrl = new URL(image);
    if (imageUrl.origin !== site.origin) return undefined;
    pathname = decodeURIComponent(imageUrl.pathname);
  } else if (image.startsWith('./images/')) {
    pathname = `/content/posts/${entryDir}/${image.slice(2)}`;
  } else if (image.startsWith('images/')) {
    pathname = `/content/posts/${entryDir}/${image}`;
  } else if (image.startsWith('/')) {
    pathname = decodeURIComponent(image);
  } else {
    pathname = `/${decodeURIComponent(image)}`;
  }

  if (pathname.startsWith('/src/content/posts/')) return pathname;
  if (pathname.startsWith('/content/posts/')) return `/src${pathname}`;

  return undefined;
}

function getPostImage(
  imageReference: string,
  entryId: string,
): ImageMetadata | undefined {
  const key = getPostImageKey(imageReference, entryId);
  if (!key) return undefined;

  return postImages[key]?.default;
}

function getFirstBodyImage(
  body: string | undefined,
  entryId: string,
): ImageMetadata | undefined {
  const match = body?.match(/!\[.*?\]\(\.\/images\/([^)]+)\)/);
  if (!match) return undefined;

  return getPostImage(`./images/${match[1]}`, entryId);
}

function getImageType(imageMetadata: ImageMetadata): string | undefined {
  if (imageMetadata.format === 'jpg') return 'image/jpeg';
  if (!imageMetadata.format) return undefined;

  return `image/${imageMetadata.format}`;
}

const frontmatterImage = entry.data.image?.trim();
const frontmatterImageKey = frontmatterImage
  ? getPostImageKey(frontmatterImage, entry.id)
  : undefined;
const frontmatterImageMetadata = frontmatterImage
  ? getPostImage(frontmatterImage, entry.id)
  : undefined;
const bodyImageMetadata = getFirstBodyImage(entry.body, entry.id);
const imageMetadata = frontmatterImageMetadata ?? bodyImageMetadata;
const resolvedImage =
  frontmatterImageMetadata?.src ??
  (!frontmatterImageKey ? frontmatterImage : undefined) ??
  bodyImageMetadata?.src;
const ogImage = resolvedImage?.startsWith('http')
  ? resolvedImage
  : resolvedImage
    ? new URL(resolvedImage, site).toString()
    : undefined;

const audioSrc = entry.data.audio;
---

<BaseLayout
  title={entry.data.title + ' - Otávio Miranda'}
  description={entry.data.description}
  image={ogImage}
  imageWidth={imageMetadata?.width}
  imageHeight={imageMetadata?.height}
  imageType={imageMetadata ? getImageType(imageMetadata) : undefined}
  imageAlt={entry.data.title}
  ogType='article'
>
  <Header />

  <ThemeToggle />

  <Section
    id='post-content'
    class='article-section'
    contentClass='section-blog'
  >
    <article class='article markdown-body article-body'>
      <header class='post-header'>
        <h1 class='post-title'>{entry.data.title}</h1>
        <div class='post-meta'>
          {
            entry.data.author && (
              <span class='post-author'>{entry.data.author}</span>
            )
          }
          {
            entry.data.date && (
              <time class='post-date' datetime={entry.data.date.toISOString()}>
                {entry.data.date.toLocaleDateString('pt-BR', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            )
          }
        </div>

        {
          audioSrc && (
            <div class='post-audio'>
              <audio controls preload='none'>
                <source src={audioSrc} type='audio/ogg; codecs=opus' />
              </audio>
            </div>
          )
        }
      </header>

      <Content />
    </article>
  </Section>

  <Section id='giscus' class='article-section' theme='dark'>
    <article class='article article-body'>
      <h2 class='title'>Comentários</h2>

      <script
        is:inline
        src='https://giscus.app/client.js'
        data-repo='luizomf/otaviomiranda.com.br'
        data-repo-id='R_kgDOKGV7BA'
        data-category='Geral'
        data-category-id='DIC_kwDOKGV7BM4C4VDU'
        data-mapping='title'
        data-strict='0'
        data-reactions-enabled='1'
        data-emit-metadata='0'
        data-input-position='top'
        data-theme='catppuccin_mocha'
        data-lang='pt'
        data-loading='lazy'
        crossorigin='anonymous'
        async></script>
    </article>
  </Section>

  <Newsletter />
  <Footer />
</BaseLayout>

<style>
  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-100) var(--space-500);
    color: var(--color-text-soft);
    font-size: var(--font-size-text-400);
  }

  .post-audio {
    margin-top: var(--space-600);
    margin-bottom: var(--space-600);
  }

  .post-audio audio {
    width: 100%;
  }
</style>
