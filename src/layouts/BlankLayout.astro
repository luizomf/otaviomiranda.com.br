---
/**
 * ARQUIVO: BlankLayout.astro
 *
 * O QUE FAZ:
 *   Layout "em branco" — fornece a estrutura HTML minima (<html>, <head>, <body>)
 *   com meta tags de SEO, mas SEM importar CSS global nem JavaScript do site.
 *   Isso cria uma tela limpa ("blank canvas") para paginas que precisam de
 *   controle total sobre estilos e scripts, como o editor Markdown.
 *
 * USADO EM:
 *   - src/pages/editor.astro (editor Markdown com Monaco Editor)
 *
 * CONCEITO ASTRO:
 *   Layouts - voce pode ter multiplos layouts no Astro. Enquanto o BaseLayout
 *   serve para paginas "normais" do site (com CSS global, Header, Footer), o
 *   BlankLayout existe para paginas que precisam de isolamento total de estilos.
 *   O <slot /> aqui funciona da mesma forma: injeta o conteudo passado como
 *   filho. As props (title, description, etc.) sao recebidas via Astro.props.
 */

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageWidth?: number;
  imageHeight?: number;
  imageType?: string;
  imageAlt?: string;
  canonical?: string;
  robots?: string;
  ogType?: string;
}

const DEFAULT_IMAGE =
  'https://otaviomiranda.com.br/imgs/curso-javascript-typescript.webp';
const DEFAULT_IMAGE_WIDTH = 830;
const DEFAULT_IMAGE_HEIGHT = 467;
const DEFAULT_IMAGE_TYPE = 'image/webp';
const DEFAULT_IMAGE_ALT = 'Curso de JavaScript e TypeScript de Otávio Miranda';

const {
  title = 'Otávio Miranda | Cursos de Programação Python, JS e Full Stack',
  description = 'Aprenda programação de verdade com Otávio Miranda. Cursos de Python, JavaScript, TypeScript e Full Stack focados em projetos reais. Mais de 300 mil alunos.',
  image = DEFAULT_IMAGE,
  imageWidth,
  imageHeight,
  imageType,
  imageAlt,
  canonical,
  robots = 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1',
  ogType = 'website',
} = Astro.props;

const site = Astro.site ?? new URL('https://otaviomiranda.com.br');
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, site).toString();
const resolvedImageWidth =
  imageWidth ?? (image === DEFAULT_IMAGE ? DEFAULT_IMAGE_WIDTH : undefined);
const resolvedImageHeight =
  imageHeight ?? (image === DEFAULT_IMAGE ? DEFAULT_IMAGE_HEIGHT : undefined);
const resolvedImageType =
  imageType ?? (image === DEFAULT_IMAGE ? DEFAULT_IMAGE_TYPE : undefined);
const resolvedImageAlt =
  imageAlt ?? (image === DEFAULT_IMAGE ? DEFAULT_IMAGE_ALT : title);
---

<!doctype html>
<html lang='pt-BR'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />

    <!-- Sitemap Link injetado (Requisito SEO) -->
    <link rel='sitemap' href='/sitemap-index.xml' />
    <link rel='icon' type='image/webp' href='/imgs/favicon-1.webp' />
    <link rel='canonical' href={canonicalUrl} />
    <meta name='robots' content={robots} />

    <!-- SEO Component Inject -->
    <title>{title}</title>
    <meta name='description' content={description} />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:type' content={ogType} />
    <meta property='og:url' content={canonicalUrl} />
    <meta property='og:site_name' content='Otávio Miranda' />
    <meta property='og:locale' content='pt_BR' />
    <meta property='og:image' content={image} />
    <meta property='og:image:secure_url' content={image} />
    {
      resolvedImageWidth && (
        <meta property='og:image:width' content={String(resolvedImageWidth)} />
      )
    }
    {
      resolvedImageHeight && (
        <meta
          property='og:image:height'
          content={String(resolvedImageHeight)}
        />
      )
    }
    {
      resolvedImageType && (
        <meta property='og:image:type' content={resolvedImageType} />
      )
    }
    {
      resolvedImageAlt && (
        <meta property='og:image:alt' content={resolvedImageAlt} />
      )
    }
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={image} />
    {
      resolvedImageAlt && (
        <meta name='twitter:image:alt' content={resolvedImageAlt} />
      )
    }

    <!-- NO GLOBAL CSS, NO GLOBAL JS. PURE HTML. -->
  </head>
  <body>
    <!-- Blank Canvas para o Desenvolvedor -->
    <slot />
  </body>
</html>
