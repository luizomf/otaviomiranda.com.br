---
/**
 * ARQUIVO: Course.astro
 *
 * O QUE FAZ:
 *   Renderiza um card individual de curso com imagem, titulo e descricao.
 *   Possui efeito de elevacao (translateY + box-shadow) ao passar o mouse,
 *   e se adapta automaticamente ao tema claro ou escuro da secao pai.
 *
 * USADO EM:
 *   - Courses.astro (renderizado via .map() para cada curso do array)
 *
 * CONCEITO ASTRO:
 *   - Astro.props: recebe dados tipados do componente pai (href, imageSrc,
 *     imageAlt, title, target, rel) via a interface "type Props".
 *   - <slot />: insere conteudo filho arbitrario (a descricao do curso)
 *     passado entre as tags <Course>...</Course> no componente pai.
 *   - Estilos com escopo (scoped styles): cada classe CSS so se aplica a
 *     este componente. O seletor :global(.section-dark) permite estilizar
 *     o card quando ele esta dentro de uma secao com tema escuro, ja que
 *     .section-dark e definida fora deste componente.
 */
type Props = {
  href: string;
  imageSrc: string;
  imageAlt: string;
  title: string;
  target?: '_blank' | '_self' | '_parent' | '_top';
  rel?: string;
};

const {
  href,
  imageSrc,
  imageAlt,
  title,
  target = '_blank',
  rel = 'noreferrer noopener',
} = Astro.props as Props;
---

<article class='course-card'>
  <a href={href} target={target} rel={rel} class='course-card-link'>
    <div class='course-card-image-wrapper'>
      <img
        loading='lazy'
        src={imageSrc}
        alt={imageAlt}
        class='course-card-image'
      />
    </div>
    <div class='course-card-content'>
      <h3 class='course-card-title'>{title}</h3>
      <p class='course-card-description'>
        <slot />
      </p>
    </div>
  </a>
</article>

<style>
  .course-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    box-shadow: var(--shadow-200);
    border: var(--border-width-100) solid var(--color-black-alpha-060);
    border-radius: var(--radius-600);
    overflow: hidden;
    transition:
      transform var(--motion-timing-medium-emphasized),
      box-shadow var(--motion-timing-medium-emphasized),
      border-color var(--motion-timing-medium-gentle);
    height: 100%;
  }

  :global(.section-dark) .course-card {
    background: var(--color-white-alpha-020);
    border: var(--border-width-100) solid var(--color-white-alpha-060);
    box-shadow: var(--shadow-300);
  }

  .course-card:hover {
    transform: translateY(calc(var(--motion-distance-200) * -1));
    box-shadow: var(--shadow-400);
    border-color: var(--color-black-alpha-120);
  }

  :global(.section-dark) .course-card:hover {
    box-shadow: var(--shadow-500);
    border-color: var(--color-white-alpha-150);
  }

  .course-card-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .course-card-image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
    background: var(--color-black-alpha-050);
  }

  :global(.section-dark) .course-card-image-wrapper {
    background: var(--color-white-alpha-050);
  }

  .course-card-image {
    opacity: 0.95;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition:
      transform var(--motion-timing-slow-emphasized),
      opacity var(--motion-timing-slow-gentle);
    margin: 0;
    border-radius: 0;
  }

  .course-card:hover .course-card-image {
    opacity: 1;
    transform: scale(1.03);
  }

  .course-card-content {
    padding: var(--space-700) var(--space-600);
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .course-card-title {
    font-size: var(--font-size-text-400);
    line-height: var(--line-height-300);
    margin: 0 0 var(--space-300) 0;
    color: var(--color-text-strong);
    transition: color var(--motion-timing-fast-gentle);
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  :global(.section-dark) .course-card-title {
    color: var(--color-text-inverse);
  }

  .course-card-description {
    font-size: var(--font-size-text-300);
    color: var(--color-text-muted);
    margin: 0;
    line-height: var(--line-height-500);
  }

  :global(.section-dark) .course-card-description {
    color: var(--color-text-subtle-on-dark);
  }
</style>
